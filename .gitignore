## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This file is a combination of several sources:
## 1. VisualStudio.gitignore from https://github.com/github/gitignore
## 2. Custom additions for .NET Core

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# [V]isual [S]tudio [C]ode config files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Visual Studio 20th Anniversary template files
*.slnx

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCop.Cache

# JetBrains Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ReSharper Personal settings
_ReSharper.命中注定

# Rider
.idea/

# Visual Studio Profiler
*.psess
*.vsp
*.vspx
*.sap

# NCrunch
_NCrunch_*
.*ncrunch*
ncrunchtemp*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
[Ee]xpress/

# DocProject is a documentation generator for .NET
DocProject/buildhelp/
DocProject/Help/*.HxT
DocProject/Help/*.HxC
DocProject/Help/*.hhc
DocProject/Help/*.hhk
DocProject/Help/*.hhp
DocProject/Help/Html2
DocProject/Help/html

# Node.js
node_modules/
npm-debug.log
yarn-error.log

# Entity Framework skip editions
*.node_modules/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Publish output
publish/

# Local settings
appsettings.json
!appsettings.json
appsettings.Development.json
